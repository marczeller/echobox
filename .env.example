# Echobox environment variables
# Copy to .env and fill in your own values. .env is gitignored.

# Hugging Face token used to download gated models:
#   - pyannote/speaker-diarization-3.1 (requires accepting the model license)
#   - pyannote/wespeaker-voxceleb-resnet34-LM (for voice identification)
# Create a token at https://huggingface.co/settings/tokens with "Read" scope.
HF_TOKEN=
